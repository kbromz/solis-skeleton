{% comment %}
  blocks/button.liquid  (create in blocks/)
  A reusable button you can drop into the custom section, groups, or any
  section that accepts @theme blocks. Three styles: primary, secondary, link.
{% endcomment %}

{%- liquid
  assign s = block.settings
-%}

{%- if s.label != blank -%}
  <a
    class="button button--{{ s.style }}{% if s.full_width %} button--block{% endif %}"
    {% if s.link != blank %}href="{{ s.link }}"{% else %}role="button"{% endif %}
    {{ block.shopify_attributes }}
  >
    {{ s.label }}
  </a>
{%- endif -%}

{% stylesheet %}
  .button--block {
    display: flex;
    width: 100%;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Button",
  "tag": null,
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "Shop now" },
    { "type": "url", "id": "link", "label": "Link" },
    {
      "type": "select", "id": "style", "label": "Style", "default": "primary",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" },
        { "value": "link", "label": "Link (underlined)" }
      ]
    },
    { "type": "checkbox", "id": "full_width", "label": "Full width", "default": false }
  ],
  "presets": [
    { "name": "Button" }
  ]
}
{% endschema %}