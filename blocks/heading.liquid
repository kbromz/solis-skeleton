{%- liquid
 assign htag = s.heading_tag
-%}



<div
  class="heading"
  style="
    text-align: {{ block.settings.alignment }};
    {% render 'typography-style',
      preset: block.settings.typography_preset,
      font: block.settings.font,
      size: block.settings.size,
      line_height: block.settings.line_height,
      letter_spacing: block.settings.letter_spacing,
      text_case: block.settings.text_case,
      wrap: block.settings.wrap
    %}
  "
  {{ block.shopify_attributes }}
>
  {{ block.settings.text }}
</div>


