{% comment %}
  blocks/heading.liquid  (replace in blocks/)
  A heading. Visual styling (preset/custom typography) is separate from the
  semantic tag, which controls the document outline for SEO/accessibility.
{% endcomment %}

{%- liquid
  assign s = block.settings
  assign htag = s.heading_tag | default: 'h2'
  assign bg = s.background
  if s.enable_overlay
    assign box_bg = 'linear-gradient(' | append: s.overlay_color | append: ', ' | append: s.overlay_color | append: '), ' | append: bg
  else
    assign box_bg = bg
  endif
-%}

<div
  class="solis-heading"
  style="
    text-align: {{ s.alignment }};
    background: {{ box_bg }};
    padding: {{ s.padding_top }}px {{ s.padding_right }}px {{ s.padding_bottom }}px {{ s.padding_left }}px;
  "
  {{ block.shopify_attributes }}
>
  <{{ htag }} class="solis-heading__text" style="margin:0; {% render 'typography-style', preset: s.heading_preset, font: s.heading_font, size: s.heading_size, line_height: s.heading_line_height, letter_spacing: s.heading_letter_spacing, text_case: s.heading_case, wrap: s.heading_wrap %}">{{ s.heading }}</{{ htag }}>
</div>

