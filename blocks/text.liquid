{% comment %}
SOLIS TEXT BLOCK — TYPOGRAPHY INTEGRATED (SAFE VERSION)
{% endcomment %}


<div
  class="solis-text"
  style="
    text-align: {{ block.settings.alignment }};
    {% render 'typography-style',
      preset: block.settings.typography_preset,
      font: block.settings.font,
      size: block.settings.size,
      line_height: block.settings.line_height,
      letter_spacing: block.settings.letter_spacing,
      text_case: block.settings.text_case,
      wrap: block.settings.wrap
    %}
  "
  {{ block.shopify_attributes }}
>
  {{ block.settings.text }}
</div>


{% schema %}
{
  "name": "Text",
  "settings": [
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Text</p>"
    },

    {
      "type": "select",
      "id": "preset",
      "label": "Typography preset",
      "default": "paragraph",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "paragraph", "label": "Paragraph" },
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" },
        { "value": "custom", "label": "Custom" }
      ]
    },

    {
      "type": "select",
      "id": "font",
      "label": "Font",
      "default": "body",
      "options": [
        { "value": "body", "label": "Body" },
        { "value": "heading", "label": "Heading" },
        { "value": "subheading", "label": "Subheading" },
        { "value": "accent", "label": "Accent" }
      ]
    },

    {
      "type": "select",
      "id": "size",
      "label": "Size",
      "default": "1rem",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "0.75rem", "label": "12" },
        { "value": "0.8125rem", "label": "13" },
        { "value": "0.875rem", "label": "14" },
        { "value": "1rem", "label": "16" },
        { "value": "1.125rem", "label": "18" },
        { "value": "1.25rem", "label": "20" },
        { "value": "1.5rem", "label": "24" },
        { "value": "2rem", "label": "32" },
        { "value": "2.75rem", "label": "44" },
        { "value": "3.5rem", "label": "56" },
        { "value": "4.5rem", "label": "72" }
      ]
    },

    {
      "type": "select",
      "id": "line_height",
      "label": "Line height",
      "default": "normal",
      "options": [
        { "value": "tight", "label": "Tight" },
        { "value": "normal", "label": "Normal" },
        { "value": "loose", "label": "Loose" }
      ]
    },

    {
      "type": "select",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "default": "normal",
      "options": [
        { "value": "tight", "label": "Tight" },
        { "value": "normal", "label": "Normal" },
        { "value": "loose", "label": "Loose" }
      ]
    },

    {
      "type": "select",
      "id": "text_case",
      "label": "Case",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "lowercase", "label": "Lowercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ]
    },

    {
      "type": "select",
      "id": "wrap",
      "label": "Wrap",
      "default": "default",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "balance", "label": "Balance" },
        { "value": "pretty", "label": "Pretty" },
        { "value": "none", "label": "None" }
      ]
    },

    {
      "type": "text_alignment",
      "id": "alignment",
      "label": "Alignment",
      "default": "left"
    }
  ],
  "presets": [
    {
      "name": "Text"
    }
  ]
}
{% endschema %}