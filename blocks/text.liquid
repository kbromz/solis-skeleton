{% comment %}
SOLIS TEXT BLOCK — TYPOGRAPHY INTEGRATED (SAFE VERSION)
{% endcomment %}


<div
  class="solis-text"
  style="
    text-align: {{ block.settings.alignment }};
    {% render 'typography-style',
      preset: block.settings.typography_preset,
      font: block.settings.font,
      size: block.settings.size,
      line_height: block.settings.line_height,
      letter_spacing: block.settings.letter_spacing,
      text_case: block.settings.text_case,
      wrap: block.settings.wrap
    %}
  "
  {{ block.shopify_attributes }}
>
  {{ block.settings.text }}
</div>


{% schema %}
{
  "name": "Text",
  "settings": [
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Text</p>"
    },

    {
      "type": "select",
      "id": "typography_preset",
      "label": "Typography preset",
      "default": "paragraph",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "paragraph", "label": "Paragraph" },
        { "value": "h1", "label": "Heading 1" },
        { "value": "h2", "label": "Heading 2" },
        { "value": "h3", "label": "Heading 3" },
        { "value": "h4", "label": "Heading 4" },
        { "value": "h5", "label": "Heading 5" },
        { "value": "h6", "label": "Heading 6" },
        { "value": "custom", "label": "Custom" }
      ]
    },

    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },

    {
      "type": "select",
      "id": "wrap",
      "label": "Text wrap",
      "default": "default",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "balance", "label": "Balance" },
        { "value": "pretty", "label": "Pretty" },
        { "value": "none", "label": "No wrap" }
      ]
    },

    {
      "type": "select",
      "id": "line_height",
      "label": "Line height",
      "default": "normal",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "tight", "label": "Tight" },
        { "value": "loose", "label": "Loose" }
      ]
    },

    {
      "type": "select",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "default": "normal",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "tight", "label": "Tight" },
        { "value": "loose", "label": "Loose" }
      ]
    },

    {
      "type": "text",
      "id": "size",
      "label": "Custom size (px/rem)"
    },

    {
      "type": "select",
      "id": "text_case",
      "label": "Text transform",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "lowercase", "label": "Lowercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Text"
    }
  ]
}
{% endschema %}