{% comment %}
  blocks/text.liquid  (replace in blocks/)
  Rich text with full typography + appearance. Rich text carries its own
  semantic tags, so there is no tag selector here (use the Heading block for
  semantic headings).
{% endcomment %}

{%- liquid
  assign s = block.settings
  assign bg = s.background
  if s.enable_overlay
    assign box_bg = 'linear-gradient(' | append: s.overlay_color | append: ', ' | append: s.overlay_color | append: '), ' | append: bg
  else
    assign box_bg = bg
  endif
-%}

<div
  class="solis-text rte"
  style="
    text-align: {{ s.alignment }};
    background: {{ box_bg }};
    padding: {{ s.padding_top }}px {{ s.padding_right }}px {{ s.padding_bottom }}px {{ s.padding_left }}px;
    {% render 'typography-style', preset: s.text_preset, font: s.text_font, size: s.text_size, line_height: s.text_line_height, letter_spacing: s.text_letter_spacing, text_case: s.text_case, wrap: s.text_wrap %}
  "
  {{ block.shopify_attributes }}
>
  {{ s.text }}
</div>

{% schema %}
{
  "name": "Text",
  "settings": [
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Add your text here.</p>"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "text_preset",
      "label": "Preset",
      "default": "paragraph",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "paragraph",
          "label": "Paragraph"
        },
        {
          "value": "h1",
          "label": "Heading 1"
        },
        {
          "value": "h2",
          "label": "Heading 2"
        },
        {
          "value": "h3",
          "label": "Heading 3"
        },
        {
          "value": "h4",
          "label": "Heading 4"
        },
        {
          "value": "h5",
          "label": "Heading 5"
        },
        {
          "value": "h6",
          "label": "Heading 6"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ]
    },
    {
      "type": "select",
      "id": "text_font",
      "label": "Font",
      "default": "body",
      "visible_if": "{{ block.settings.text_preset == 'custom' }}",
      "options": [
        {
          "value": "body",
          "label": "Body"
        },
        {
          "value": "subheading",
          "label": "Subheading"
        },
        {
          "value": "heading",
          "label": "Heading"
        },
        {
          "value": "accent",
          "label": "Accent"
        }
      ]
    },
    {
      "type": "select",
      "id": "text_size",
      "label": "Size",
      "default": "1rem",
      "visible_if": "{{ block.settings.text_preset == 'custom' }}",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "0.75rem",
          "label": "12"
        },
        {
          "value": "0.8125rem",
          "label": "13"
        },
        {
          "value": "0.875rem",
          "label": "14"
        },
        {
          "value": "1rem",
          "label": "16"
        },
        {
          "value": "1.125rem",
          "label": "18"
        },
        {
          "value": "1.25rem",
          "label": "20"
        },
        {
          "value": "1.5rem",
          "label": "24"
        },
        {
          "value": "2rem",
          "label": "32"
        },
        {
          "value": "2.75rem",
          "label": "44"
        },
        {
          "value": "3.5rem",
          "label": "56"
        },
        {
          "value": "4.5rem",
          "label": "72"
        }
      ]
    },
    {
      "type": "select",
      "id": "text_line_height",
      "label": "Line height",
      "default": "normal",
      "visible_if": "{{ block.settings.text_preset == 'custom' }}",
      "options": [
        {
          "value": "tight",
          "label": "Tight"
        },
        {
          "value": "normal",
          "label": "Normal"
        },
        {
          "value": "loose",
          "label": "Loose"
        }
      ]
    },
    {
      "type": "select",
      "id": "text_letter_spacing",
      "label": "Letter spacing",
      "default": "normal",
      "visible_if": "{{ block.settings.text_preset == 'custom' }}",
      "options": [
        {
          "value": "tight",
          "label": "Tight"
        },
        {
          "value": "normal",
          "label": "Normal"
        },
        {
          "value": "loose",
          "label": "Loose"
        }
      ]
    },
    {
      "type": "select",
      "id": "text_case",
      "label": "Case",
      "default": "none",
      "visible_if": "{{ block.settings.text_preset == 'custom' }}",
      "options": [
        {
          "value": "none",
          "label": "Default"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        }
      ]
    },
    {
      "type": "select",
      "id": "text_wrap",
      "label": "Wrap",
      "default": "pretty",
      "visible_if": "{{ block.settings.text_preset == 'custom' }}",
      "options": [
        {
          "value": "pretty",
          "label": "Pretty"
        },
        {
          "value": "balance",
          "label": "Balance"
        },
        {
          "value": "none",
          "label": "None"
        }
      ]
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Text alignment",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "color_background",
      "id": "background",
      "label": "Background",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "checkbox",
      "id": "enable_overlay",
      "label": "Background overlay",
      "default": false
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#00000026",
      "visible_if": "{{ block.settings.enable_overlay }}"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "Right",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "Left",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Text"
    }
  ]
}
{% endschema %}