{% comment %}
  blocks/slide.liquid  (create in blocks/)
  One hero slide. Split media (image/video x2) with mobile behavior,
  9-point content position for desktop + mobile, inline content, overlay.
{% endcomment %}

{%- liquid
  assign s = block.settings
  assign is_first = false
  if section.blocks.first.id == block.id
    assign is_first = true
  endif

  assign load1 = 'lazy'
  if is_first
    assign load1 = 'eager'
  endif

  assign pd = s.content_position_desktop | split: '-'
  assign pm = s.content_position_mobile | split: '-'

  case pd[0]
    when 'top'
      assign ay_d = 'start'
    when 'bottom'
      assign ay_d = 'end'
    else
      assign ay_d = 'center'
  endcase
  case pd[1]
    when 'left'
      assign ax_d = 'start'
      assign talign_d = 'left'
    when 'right'
      assign ax_d = 'end'
      assign talign_d = 'right'
    else
      assign ax_d = 'center'
      assign talign_d = 'center'
  endcase

  case pm[0]
    when 'top'
      assign ay_m = 'start'
    when 'bottom'
      assign ay_m = 'end'
    else
      assign ay_m = 'center'
  endcase
  case pm[1]
    when 'left'
      assign ax_m = 'start'
      assign talign_m = 'left'
    when 'right'
      assign ax_m = 'end'
      assign talign_m = 'right'
    else
      assign ax_m = 'center'
      assign talign_m = 'center'
  endcase

  if s.overlay_style == 'gradient'
    assign overlay_bg = 'linear-gradient(' | append: s.gradient_direction | append: ', ' | append: s.overlay_color | append: ', transparent)'
  else
    assign overlay_bg = s.overlay_color
  endif
-%}

<div
  class="hero__slide{% unless s.inherit_color_scheme %} color-{{ s.color_scheme }}{% endunless %}{% if is_first %} is-active{% endif %}"
  style="
    --ay-d: {{ ay_d }}; --ax-d: {{ ax_d }}; --talign-d: {{ talign_d }};
    --ay-m: {{ ay_m }}; --ax-m: {{ ax_m }}; --talign-m: {{ talign_m }};
    --content-mw: {{ s.content_max_width }}px;
    --heading-size: {{ s.heading_size }};
    --split-gap: {{ s.split_gap }}px;
  "
  {{ block.shopify_attributes }}
>
  <div class="hero__media{% if s.enable_split %} hero__media--split hero__media--m-{{ s.mobile_media }}{% endif %}">
    <div class="hero__media-item">
      {%- if s.media_type_1 == 'video' and s.video_1 != blank -%}
        {{ s.video_1 | video_tag: loop: true, autoplay: true, muted: true, controls: false, playsinline: true, image_size: '1600x' }}
      {%- elsif s.image_1 != blank -%}
        {{ s.image_1 | image_url: width: 2200 | image_tag: class: 'hero__img', widths: '600,1000,1600,2200', sizes: '100vw', loading: load1, alt: s.image_1.alt }}
      {%- else -%}
        {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero__img placeholder' }}
      {%- endif -%}
    </div>

    {%- if s.enable_split -%}
      <div class="hero__media-item hero__media-item--2">
        {%- if s.media_type_2 == 'video' and s.video_2 != blank -%}
          {{ s.video_2 | video_tag: loop: true, autoplay: true, muted: true, controls: false, playsinline: true, image_size: '1600x' }}
        {%- elsif s.image_2 != blank -%}
          {{ s.image_2 | image_url: width: 2200 | image_tag: class: 'hero__img', widths: '600,1000,1600,2200', sizes: '50vw', loading: 'lazy', alt: s.image_2.alt }}
        {%- else -%}
          {{ 'hero-apparel-2' | placeholder_svg_tag: 'hero__img placeholder' }}
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  {%- if s.toggle_overlay -%}
    <div class="hero__overlay" style="background: {{ overlay_bg }};"></div>
  {%- endif -%}

  <div class="hero__content">
    {%- if s.eyebrow != blank -%}<p class="hero__eyebrow">{{ s.eyebrow }}</p>{%- endif -%}
    {%- if s.heading != blank -%}<h2 class="hero__heading">{{ s.heading }}</h2>{%- endif -%}
    {%- if s.body != blank -%}<div class="hero__body rte">{{ s.body }}</div>{%- endif -%}
    {%- if s.button_1_label != blank or s.button_2_label != blank -%}
      <div class="hero__buttons">
        {%- if s.button_1_label != blank -%}
          <a href="{{ s.button_1_link }}" class="button button--{{ s.button_1_style }}">{{ s.button_1_label }}</a>
        {%- endif -%}
        {%- if s.button_2_label != blank -%}
          <a href="{{ s.button_2_link }}" class="button button--{{ s.button_2_style }}">{{ s.button_2_label }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .hero__slide {
    position: relative;
    display: grid;
    min-height: var(--slide-h, 82vh);
    place-items: stretch;
    isolation: isolate;
  }
  .hero__media { position: absolute; inset: 0; z-index: 0; display: grid; }
  .hero__media--split { grid-template-columns: 1fr 1fr; gap: var(--split-gap, 0); }
  .hero__media-item { position: relative; overflow: hidden; }
  .hero__img, .hero__media-item video {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
  }
  .hero__overlay { position: absolute; inset: 0; z-index: 1; }

  .hero__content {
    position: relative;
    z-index: 2;
    align-self: var(--ay-d, center);
    justify-self: var(--ax-d, center);
    justify-items: var(--ax-d, center);
    text-align: var(--talign-d, center);
    display: grid;
    gap: 1rem;
    max-width: var(--content-mw, 540px);
    padding: clamp(1.5rem, 5vw, 4rem);
  }
  .hero__eyebrow {
    margin: 0;
    font-family: var(--font-subheading--family);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.8125rem;
  }
  .hero__heading {
    margin: 0;
    font-family: var(--font-heading--family);
    font-size: var(--heading-size, 3rem);
    line-height: 1.05;
  }
  .hero__body { max-width: 46ch; }
  .hero__buttons { display: flex; flex-wrap: wrap; gap: 0.75rem; }

  @media (max-width: 749px) {
    .hero__content {
      align-self: var(--ay-m, center);
      justify-self: var(--ax-m, center);
      justify-items: var(--ax-m, center);
      text-align: var(--talign-m, center);
    }
    .hero__media--m-stack { grid-template-columns: 1fr; grid-auto-rows: 1fr; }
    .hero__media--m-first_only { grid-template-columns: 1fr; }
    .hero__media--m-first_only .hero__media-item--2 { display: none; }
    .hero__media--m-second_only { grid-template-columns: 1fr; }
    .hero__media--m-second_only .hero__media-item:not(.hero__media-item--2) { display: none; }
    .hero__heading { font-size: clamp(2rem, 9vw, var(--heading-size, 3rem)); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Slide",
  "tag": null,
  "settings": [
    { "type": "header", "content": "Media" },
    {
      "type": "select", "id": "media_type_1", "label": "Media type", "default": "image",
      "options": [ { "value": "image", "label": "Image" }, { "value": "video", "label": "Video" } ]
    },
    { "type": "image_picker", "id": "image_1", "label": "Image" },
    { "type": "video", "id": "video_1", "label": "Video" },
    { "type": "checkbox", "id": "enable_split", "label": "Split media (two side by side)", "default": false },
    {
      "type": "select", "id": "media_type_2", "label": "Second media type", "default": "image",
      "visible_if": "{{ block.settings.enable_split }}",
      "options": [ { "value": "image", "label": "Image" }, { "value": "video", "label": "Video" } ]
    },
    { "type": "image_picker", "id": "image_2", "label": "Second image", "visible_if": "{{ block.settings.enable_split }}" },
    { "type": "video", "id": "video_2", "label": "Second video", "visible_if": "{{ block.settings.enable_split }}" },
    { "type": "range", "id": "split_gap", "label": "Gap between media", "min": 0, "max": 40, "step": 1, "unit": "px", "default": 0, "visible_if": "{{ block.settings.enable_split }}" },
    {
      "type": "select", "id": "mobile_media", "label": "On mobile", "default": "stack",
      "visible_if": "{{ block.settings.enable_split }}",
      "options": [
        { "value": "stack", "label": "Stack both" },
        { "value": "first_only", "label": "First only" },
        { "value": "second_only", "label": "Second only" }
      ]
    },

    { "type": "header", "content": "Content position" },
    {
      "type": "select", "id": "content_position_desktop", "label": "Desktop", "default": "center-left",
      "options": [
        { "value": "top-left", "label": "Top left" },
        { "value": "top-center", "label": "Top center" },
        { "value": "top-right", "label": "Top right" },
        { "value": "center-left", "label": "Center left" },
        { "value": "center-center", "label": "Center" },
        { "value": "center-right", "label": "Center right" },
        { "value": "bottom-left", "label": "Bottom left" },
        { "value": "bottom-center", "label": "Bottom center" },
        { "value": "bottom-right", "label": "Bottom right" }
      ]
    },
    {
      "type": "select", "id": "content_position_mobile", "label": "Mobile", "default": "bottom-center",
      "options": [
        { "value": "top-left", "label": "Top left" },
        { "value": "top-center", "label": "Top center" },
        { "value": "top-right", "label": "Top right" },
        { "value": "center-left", "label": "Center left" },
        { "value": "center-center", "label": "Center" },
        { "value": "center-right", "label": "Center right" },
        { "value": "bottom-left", "label": "Bottom left" },
        { "value": "bottom-center", "label": "Bottom center" },
        { "value": "bottom-right", "label": "Bottom right" }
      ]
    },

    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Your headline here" },
    {
      "type": "select", "id": "heading_size", "label": "Heading size", "default": "3.5rem",
      "options": [
        { "value": "2rem", "label": "Small" },
        { "value": "2.75rem", "label": "Medium" },
        { "value": "3.5rem", "label": "Large" },
        { "value": "4.5rem", "label": "X-Large" }
      ]
    },
    { "type": "richtext", "id": "body", "label": "Body" },
    { "type": "range", "id": "content_max_width", "label": "Content width", "min": 320, "max": 800, "step": 10, "unit": "px", "default": 540 },

    { "type": "header", "content": "Buttons" },
    { "type": "text", "id": "button_1_label", "label": "Button 1 label" },
    { "type": "url", "id": "button_1_link", "label": "Button 1 link" },
    {
      "type": "select", "id": "button_1_style", "label": "Button 1 style", "default": "primary",
      "options": [ { "value": "primary", "label": "Primary" }, { "value": "secondary", "label": "Secondary" }, { "value": "link", "label": "Link" } ]
    },
    { "type": "text", "id": "button_2_label", "label": "Button 2 label" },
    { "type": "url", "id": "button_2_link", "label": "Button 2 link" },
    {
      "type": "select", "id": "button_2_style", "label": "Button 2 style", "default": "link",
      "options": [ { "value": "primary", "label": "Primary" }, { "value": "secondary", "label": "Secondary" }, { "value": "link", "label": "Link" } ]
    },

    { "type": "header", "content": "Appearance" },
    { "type": "checkbox", "id": "inherit_color_scheme", "label": "Inherit section color scheme", "default": true },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1", "visible_if": "{{ block.settings.inherit_color_scheme == false }}" },
    { "type": "checkbox", "id": "toggle_overlay", "label": "Show overlay", "default": false },
    { "type": "color", "id": "overlay_color", "label": "Overlay color", "default": "#00000040" },
    {
      "type": "select", "id": "overlay_style", "label": "Overlay style", "default": "solid",
      "options": [ { "value": "solid", "label": "Solid" }, { "value": "gradient", "label": "Gradient" } ]
    },
    {
      "type": "select", "id": "gradient_direction", "label": "Gradient direction", "default": "to top",
      "visible_if": "{{ block.settings.overlay_style == 'gradient' }}",
      "options": [
        { "value": "to top", "label": "To top" },
        { "value": "to bottom", "label": "To bottom" },
        { "value": "to right", "label": "To right" },
        { "value": "to left", "label": "To left" }
      ]
    }
  ],
  "presets": [ { "name": "Slide" } ]
}
{% endschema %}