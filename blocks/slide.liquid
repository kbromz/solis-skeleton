{% comment %}
  blocks/slide.liquid  (replace in blocks/)
  Hero slide. Split media, 9-point position (desktop + mobile), preset-based
  typography per element, a semantic heading tag (separate from visual size)
  for accessibility, and 4-side padding.
{% endcomment %}

{%- liquid
  assign s = block.settings
  assign is_first = false
  if section.blocks.first.id == block.id
    assign is_first = true
  endif
  assign load1 = 'lazy'
  if is_first
    assign load1 = 'eager'
  endif

  assign pd = s.content_position_desktop | split: '-'
  assign pm = s.content_position_mobile | split: '-'
  case pd[0]
    when 'top'
      assign ay_d = 'start'
    when 'bottom'
      assign ay_d = 'end'
    else
      assign ay_d = 'center'
  endcase
  case pd[1]
    when 'left'
      assign ax_d = 'start'
      assign talign_d = 'left'
    when 'right'
      assign ax_d = 'end'
      assign talign_d = 'right'
    else
      assign ax_d = 'center'
      assign talign_d = 'center'
  endcase
  case pm[0]
    when 'top'
      assign ay_m = 'start'
    when 'bottom'
      assign ay_m = 'end'
    else
      assign ay_m = 'center'
  endcase
  case pm[1]
    when 'left'
      assign ax_m = 'start'
      assign talign_m = 'left'
    when 'right'
      assign ax_m = 'end'
      assign talign_m = 'right'
    else
      assign ax_m = 'center'
      assign talign_m = 'center'
  endcase

  if s.overlay_style == 'gradient'
    assign overlay_bg = 'linear-gradient(' | append: s.gradient_direction | append: ', ' | append: s.overlay_color | append: ', transparent)'
  else
    assign overlay_bg = s.overlay_color
  endif

  assign htag = s.heading_tag
  assign slide_label = s.heading | strip_html | default: 'Slide'
-%}

<div
  class="hero__slide{% unless s.inherit_color_scheme %} color-{{ s.color_scheme }}{% endunless %}{% if is_first %} is-active{% endif %}"
  role="group"
  aria-roledescription="slide"
  aria-label="{{ slide_label }}"
  style="
    --ay-d: {{ ay_d }}; --ax-d: {{ ax_d }}; --talign-d: {{ talign_d }};
    --ay-m: {{ ay_m }}; --ax-m: {{ ax_m }}; --talign-m: {{ talign_m }};
    --content-mw: {{ s.content_max_width }}px;
    --split-gap: {{ s.split_gap }}px;
    --pad-t: {{ s.padding_top }}px; --pad-r: {{ s.padding_right }}px; --pad-b: {{ s.padding_bottom }}px; --pad-l: {{ s.padding_left }}px;
  "
  {{ block.shopify_attributes }}
>
  <div class="hero__media{% if s.enable_split %} hero__media--split hero__media--m-{{ s.mobile_media }}{% endif %}">
    <div class="hero__media-item">
      {%- if s.media_type_1 == 'video' and s.video_1 != blank -%}
        {{ s.video_1 | video_tag: loop: true, autoplay: true, muted: true, controls: false, playsinline: true, image_size: '1600x' }}
      {%- elsif s.image_1 != blank -%}
        {{ s.image_1 | image_url: width: 2200 | image_tag: class: 'hero__img', widths: '600,1000,1600,2200', sizes: '100vw', loading: load1, alt: s.image_1.alt }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'hero__img placeholder' }}
      {%- endif -%}
    </div>
    {%- if s.enable_split -%}
      <div class="hero__media-item hero__media-item--2">
        {%- if s.media_type_2 == 'video' and s.video_2 != blank -%}
          {{ s.video_2 | video_tag: loop: true, autoplay: true, muted: true, controls: false, playsinline: true, image_size: '1600x' }}
        {%- elsif s.image_2 != blank -%}
          {{ s.image_2 | image_url: width: 2200 | image_tag: class: 'hero__img', widths: '600,1000,1600,2200', sizes: '50vw', loading: 'lazy', alt: s.image_2.alt }}
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'hero__img placeholder' }}
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  {%- if s.toggle_overlay -%}
    <div class="hero__overlay" style="background: {{ overlay_bg }};" aria-hidden="true"></div>
  {%- endif -%}

  <div class="hero__content">
    {%- if s.eyebrow != blank -%}
      <p class="hero__eyebrow" style="{% render 'typography-style', preset: s.eyebrow_preset, font: s.eyebrow_font, size: s.eyebrow_size, line_height: s.eyebrow_line_height, letter_spacing: s.eyebrow_letter_spacing, text_case: s.eyebrow_case, wrap: s.eyebrow_wrap %}">{{ s.eyebrow }}</p>
    {%- endif -%}
    {%- if s.heading != blank -%}
      <{{ htag }} class="hero__heading" style="{% render 'typography-style', preset: s.heading_preset, font: s.heading_font, size: s.heading_size, line_height: s.heading_line_height, letter_spacing: s.heading_letter_spacing, text_case: s.heading_case, wrap: s.heading_wrap %}">{{ s.heading }}</{{ htag }}>
    {%- endif -%}
    {%- if s.body != blank -%}
      <div class="hero__body rte" style="{% render 'typography-style', preset: s.body_preset, font: s.body_font, size: s.body_size, line_height: s.body_line_height, letter_spacing: s.body_letter_spacing, text_case: s.body_case, wrap: s.body_wrap %}">{{ s.body }}</div>
    {%- endif -%}
    {%- if s.button_1_label != blank or s.button_2_label != blank -%}
      <div class="hero__buttons">
        {%- if s.button_1_label != blank -%}<a href="{{ s.button_1_link }}" class="button button--{{ s.button_1_style }}">{{ s.button_1_label }}</a>{%- endif -%}
        {%- if s.button_2_label != blank -%}<a href="{{ s.button_2_link }}" class="button button--{{ s.button_2_style }}">{{ s.button_2_label }}</a>{%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .hero__slide {
    position: relative; display: grid;
    min-height: var(--slide-h, 82vh);
    place-items: stretch; isolation: isolate;
  }
  .hero__media { position: absolute; inset: 0; z-index: 0; display: grid; }
  .hero__media--split { grid-template-columns: 1fr 1fr; gap: var(--split-gap, 0); }
  .hero__media-item { position: relative; overflow: hidden; }
  .hero__img, .hero__media-item video { width: 100%; height: 100%; object-fit: cover; display: block; }
  .hero__overlay { position: absolute; inset: 0; z-index: 1; }

  .hero__content {
    position: relative; z-index: 2;
    align-self: var(--ay-d, center);
    justify-self: var(--ax-d, center);
    justify-items: var(--ax-d, center);
    text-align: var(--talign-d, center);
    display: grid; gap: 1rem;
    max-width: var(--content-mw, 540px);
    padding: var(--pad-t, 48px) var(--pad-r, 48px) var(--pad-b, 48px) var(--pad-l, 48px);
  }
  .hero__eyebrow, .hero__heading { margin: 0; }
  .hero__body { max-width: 46ch; }
  .hero__buttons { display: flex; flex-wrap: wrap; gap: 0.75rem; }

  @media (max-width: 749px) {
    .hero__slide { min-height: var(--slide-h-mobile, var(--slide-h, 65vh)); }
    .hero__content {
      align-self: var(--ay-m, center);
      justify-self: var(--ax-m, center);
      justify-items: var(--ax-m, center);
      text-align: var(--talign-m, center);
    }
    .hero__media--m-stack { grid-template-columns: 1fr; grid-auto-rows: 1fr; }
    .hero__media--m-first_only { grid-template-columns: 1fr; }
    .hero__media--m-first_only .hero__media-item--2 { display: none; }
    .hero__media--m-second_only { grid-template-columns: 1fr; }
    .hero__media--m-second_only .hero__media-item:not(.hero__media-item--2) { display: none; }
  }
{% endstylesheet %}

