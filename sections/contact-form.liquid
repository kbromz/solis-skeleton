<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} section-wrapper"
  data-testid="ui-test-section"
  {% if request.visual_preview_mode %}data-shopify-visual-preview{% endif %}
  style="
    {% if section.settings.section_height == 'custom' %}--section-min-height: {{ section.settings.section_height_custom }}svh;
    {% elsif section.settings.section_height == 'full-screen' %}--section-min-height: 100svh;
    {% elsif section.settings.section_height != '' %}--section-min-height: var(--section-height-{{ section.settings.section_height }});
    {% endif %}
    {% if section.settings.section_height != '' %}--section-preview-height: 600px;{% endif %}
  "
>
  <div class="custom-section-background">
    {% render 'background-media',
      background_media: section.settings.background_media,
      background_video: section.settings.video,
      background_video_position: section.settings.video_position,
      background_image: section.settings.background_image,
      background_image_position: section.settings.background_image_position
    %}
  </div>

  <div
    class="border-style custom-section-content"
    style="{% render 'border-override', settings: section.settings %}"
  >
    {% if section.settings.toggle_overlay %}
      {% render 'overlay', settings: section.settings, layer: '0' %}
    {% endif %}

    <div
      class="spacing-style layout-panel-flex layout-panel-flex--{{ section.settings.content_direction }} section-content-wrapper{% if section.settings.vertical_on_mobile %} mobile-column{% endif %}"
      style="{% render 'layout-panel-style', settings: section.settings %}{% render 'spacing-style', settings: section.settings %}"
      data-testid="section-content"
    >

      <div
        class="contact-form-section__form-wrapper {{ section.settings.field_type_preset }}{% if section.settings.field_type_preset == 'custom' %} custom-typography{% endif %}"
        style="
          {%- if section.settings.field_type_preset == 'custom' -%}
            {%- if section.settings.field_font_size != blank -%}--font-size: {{ section.settings.field_font_size }};{%- endif -%}
            --font-family: {{ section.settings.field_font }};
            --text-transform: {{ section.settings.field_case }};
            --letter-spacing: var(--letter-spacing--body-{{ section.settings.field_letter_spacing }});
          {%- endif -%}
        "
      >
        {%- assign form_id = section.id | prepend: 'ContactForm-' -%}
        {%- form 'contact', id: form_id, class: 'contact-form__form' -%}

          <input name="contact[id]" type="hidden" value="{{ form_id }}">

          {%- if form.errors and form.id == form_id -%}
            <div class="contact-form__error" tabindex="-1" autofocus>
              {{- 'icon-error.svg' | inline_asset_content -}}
              {{- form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email -}}
            </div>
          {%- endif -%}

          {%- if form.posted_successfully? and form.id == form_id -%}
            <div class="contact-form__success" tabindex="-1" autofocus>
              {{- 'icon-checkmark.svg' | inline_asset_content -}}
              {{- 'blocks.contact_form.post_success' | t -}}
            </div>
          {%- endif -%}

          <div class="contact-form__form-row">
            <label class="visually-hidden" for="ContactForm-name">{{ 'blocks.contact_form.name' | t }}</label>
            <input
              type="text"
              id="ContactForm-name"
              class="contact-form__input"
              autocomplete="name"
              name="contact[name]"
              value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
              placeholder="{{ 'blocks.contact_form.name' | t }}"
            >
            <label class="visually-hidden" for="ContactForm-email">{{ 'blocks.contact_form.email' | t }} <span aria-hidden="true">*</span></label>
            <input
              type="email"
              id="ContactForm-email"
              class="contact-form__input"
              autocomplete="email"
              name="contact[email]"
              spellcheck="false"
              autocapitalize="off"
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              aria-required="true"
              {% if form.errors contains 'email' and form.id == form_id %}aria-invalid="true"{% endif %}
              placeholder="{{ 'blocks.contact_form.email' | t }}"
            >
          </div>

          <label class="visually-hidden" for="ContactForm-phone">{{ 'blocks.contact_form.phone' | t }}</label>
          <input
            type="tel"
            id="ContactForm-phone"
            class="contact-form__input"
            autocomplete="tel"
            name="contact[phone]"
            pattern="[0-9\-]*"
            value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
            placeholder="{{ 'blocks.contact_form.phone' | t }}"
          >

          {%- comment -%} Custom fields {%- endcomment -%}
          {%- assign field_types = 'field_text,field_textarea,field_phone,field_date,field_dropdown,field_radio,field_checkbox' -%}
          {%- for block in section.blocks -%}
            {%- unless field_types contains block.type -%}{%- continue -%}{%- endunless -%}

            {%- assign field_label = block.settings.label -%}
            {%- assign field_key   = block.settings.field_key | default: field_label | handleize -%}
            {%- assign required    = block.settings.required -%}
            {%- assign placeholder = block.settings.placeholder | default: field_label -%}
            {%- assign element_id  = 'ContactField-' | append: block.id -%}

            <div class="contact-form-field" {{ block.shopify_attributes }}>

              {%- if field_label != blank -%}
                <label class="contact-form-field__label" for="{{ element_id }}">
                  {{ field_label | escape }}
                  {%- if required -%}<span class="contact-form-field__required" aria-hidden="true"> *</span>{%- endif -%}
                </label>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <p class="contact-form-field__description">{{ block.settings.description | escape }}</p>
              {%- endif -%}

              {%- case block.type -%}

                {%- when 'field_text' -%}
                  <input
                    type="text"
                    id="{{ element_id }}"
                    name="contact[{{ field_key }}]"
                    class="contact-form__input"
                    placeholder="{{ placeholder | escape }}"
                    {% if required %}required aria-required="true"{% endif %}
                  >

                {%- when 'field_textarea' -%}
                  <textarea
                    id="{{ element_id }}"
                    name="contact[{{ field_key }}]"
                    class="contact-form__input contact-form__input--textarea"
                    placeholder="{{ placeholder | escape }}"
                    rows="{{ block.settings.rows | default: 4 }}"
                    {% if required %}required aria-required="true"{% endif %}
                  ></textarea>

                {%- when 'field_phone' -%}
                  <input
                    type="tel"
                    id="{{ element_id }}"
                    name="contact[{{ field_key }}]"
                    class="contact-form__input"
                    autocomplete="tel"
                    placeholder="{{ placeholder | escape }}"
                    {% if required %}required aria-required="true"{% endif %}
                  >

                {%- when 'field_date' -%}
                  <input
                    type="date"
                    id="{{ element_id }}"
                    name="contact[{{ field_key }}]"
                    class="contact-form__input"
                    {% if block.settings.date_min != blank %}min="{{ block.settings.date_min }}"{% endif %}
                    {% if block.settings.date_max != blank %}max="{{ block.settings.date_max }}"{% endif %}
                    {% if required %}required aria-required="true"{% endif %}
                  >

                {%- when 'field_dropdown' -%}
                  {%- assign options_list = block.settings.options | split: ',' -%}
                  <div class="contact-form-field__select-wrapper">
                    <select
                      id="{{ element_id }}"
                      name="contact[{{ field_key }}]"
                      class="contact-form__input contact-form__input--select"
                      {% if required %}required aria-required="true"{% endif %}
                    >
                      <option value="" disabled selected>{{ placeholder | escape }}</option>
                      {%- for option in options_list -%}
                        {%- assign opt = option | strip -%}
                        {%- if opt != blank -%}
                          <option value="{{ opt | handleize }}">{{ opt | escape }}</option>
                        {%- endif -%}
                      {%- endfor -%}
                    </select>
                    <span class="contact-form-field__select-arrow" aria-hidden="true">
                      {{- 'icon-arrow.svg' | inline_asset_content -}}
                    </span>
                  </div>

                {%- when 'field_radio' -%}
                  {%- assign options_list = block.settings.options | split: ',' -%}
                  <fieldset class="contact-form-field__fieldset">
                    <legend class="visually-hidden">{{ field_label | escape }}</legend>
                    {%- for option in options_list -%}
                      {%- assign opt = option | strip -%}
                      {%- if opt != blank -%}
                        {%- assign radio_id = element_id | append: '-' | append: forloop.index -%}
                        <div class="contact-form-field__radio-row">
                          <input
                            type="radio"
                            id="{{ radio_id }}"
                            name="contact[{{ field_key }}]"
                            value="{{ opt | handleize }}"
                            class="contact-form-field__radio"
                            {% if required and forloop.first %}required aria-required="true"{% endif %}
                          >
                          <label for="{{ radio_id }}" class="contact-form-field__radio-label">{{ opt | escape }}</label>
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </fieldset>

                {%- when 'field_checkbox' -%}
                  <div class="contact-form-field__checkbox-row">
                    <input
                      type="checkbox"
                      id="{{ element_id }}"
                      name="contact[{{ field_key }}]"
                      value="yes"
                      class="contact-form-field__checkbox"
                      {% if required %}required aria-required="true"{% endif %}
                    >
                    {%- if block.settings.checkbox_label != blank -%}
                      <label for="{{ element_id }}" class="contact-form-field__checkbox-label">
                        {{ block.settings.checkbox_label }}
                      </label>
                    {%- endif -%}
                  </div>

              {%- endcase -%}
            </div>
          {%- endfor -%}

          <label class="visually-hidden" for="ContactForm-body">{{ 'blocks.contact_form.comment' | t }}</label>
          <textarea
            rows="10"
            id="ContactForm-body"
            class="contact-form__input contact-form__input--textarea"
            name="contact[body]"
            placeholder="{{ 'blocks.contact_form.comment' | t }}"
          >{{- form.body -}}</textarea>

          <div class="contact-form__submit">
            <button type="submit" class="{% if section.settings.button_style == 'link' %}link{% else %}button {{ section.settings.button_style }}{% endif %}">
              {{ section.settings.button_label | default: 'Submit' }}
            </button>
          </div>

        {%- endform -%}
      </div>

    </div>
  </div>
</div>

{% stylesheet %}
  .section-wrapper {
    --section-height-offset: 0px;
  }

  .custom-section-background {
    grid-column: 1 / -1;
  }

  .custom-section-content {
    z-index: var(--layer-flat);
  }

  .contact-form-section__form-wrapper {
    flex: 1;
    min-width: 0;
  }

  .contact-form__form {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
  }

  .contact-form__form-row {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
  }

  @media screen and (min-width: 750px) {
    .contact-form__form-row {
      flex-direction: row;
      align-items: center;
    }
  }

  .contact-form__input {
    width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--color-input-text);
    background-color: var(--color-input-background);
    padding: var(--padding-lg) var(--padding-xl);
    border-radius: var(--style-border-radius-inputs);
    border: var(--style-border-width-inputs) solid var(--color-input-border);
    -webkit-font-smoothing: antialiased;
  }

  .contact-form__input--textarea {
    resize: vertical;
    min-height: var(--input-textarea-min-height);
    overflow: hidden;
    text-overflow: unset;
  }

  .contact-form__error,
  .contact-form__success {
    display: flex;
    align-items: center;
    gap: var(--gap-xs);
  }

  .contact-form__submit {
    display: flex;
  }

  .contact-form__submit button.link {
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    font: inherit;
  }

  .contact-form-field {
    display: flex;
    flex-direction: column;
    gap: var(--gap-xs);
  }

  .contact-form-field__label {
    font-size: 0.875em;
    font-weight: 500;
  }

  .contact-form-field__required {
    color: var(--color-error, currentcolor);
  }

  .contact-form-field__description {
    font-size: min(0.85em, var(--font-paragraph--size));
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
    margin: 0;
  }

  .contact-form-field__select-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .contact-form__input--select {
    appearance: none;
    -webkit-appearance: none;
    cursor: pointer;
    padding-right: 2.5rem;
  }

  .contact-form-field__select-arrow {
    position: absolute;
    right: var(--padding-lg);
    pointer-events: none;
    display: flex;
    align-items: center;
    transform: rotate(90deg);
    opacity: 0.6;
  }

  .contact-form-field__select-arrow svg {
    width: 0.75rem;
    height: 0.75rem;
  }

  .contact-form-field__fieldset {
    border: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm);
  }

  .contact-form-field__radio-row {
    display: flex;
    align-items: center;
    gap: var(--gap-sm);
  }

  .contact-form-field__radio {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    cursor: pointer;
    accent-color: var(--color-button);
  }

  .contact-form-field__radio-label {
    cursor: pointer;
    line-height: 1.4;
  }

  .contact-form-section__form-wrapper .contact-form__input::placeholder {
    font-family: inherit;
    font-size: inherit;
    letter-spacing: inherit;
    text-transform: inherit;
    opacity: 0.6;
  }

  .contact-form-section__form-wrapper .contact-form-field__label,
  .contact-form-section__form-wrapper .contact-form-field__description {
    font-family: inherit;
    font-size: inherit;
    letter-spacing: inherit;
    text-transform: inherit;
  }

  .contact-form-field__checkbox-row {
    display: flex;
    align-items: flex-start;
    gap: var(--gap-sm);
  }

  .contact-form-field__checkbox {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    margin-top: 0.2em;
    cursor: pointer;
    accent-color: var(--color-button);
  }

  .contact-form-field__checkbox-label {
    cursor: pointer;
    line-height: 1.5;
  }

  .contact-form-field__checkbox-label a {
    color: var(--color-primary);
    text-decoration: underline;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Contact form",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "field_text",
      "name": "Text field",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Your question" },
        { "type": "text", "id": "description", "label": "Helper text" },
        { "type": "text", "id": "field_key", "label": "Field key", "info": "Used as the field name in the email you receive.", "default": "custom-field" },
        { "type": "text", "id": "placeholder", "label": "Placeholder" },
        { "type": "checkbox", "id": "required", "label": "Required", "default": false }
      ]
    },
    {
      "type": "field_textarea",
      "name": "Long text",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Your message" },
        { "type": "text", "id": "description", "label": "Helper text" },
        { "type": "text", "id": "field_key", "label": "Field key", "info": "Used as the field name in the email you receive.", "default": "custom-field" },
        { "type": "text", "id": "placeholder", "label": "Placeholder" },
        { "type": "range", "id": "rows", "label": "Rows", "min": 2, "max": 12, "step": 1, "default": 4 },
        { "type": "checkbox", "id": "required", "label": "Required", "default": false }
      ]
    },
    {
      "type": "field_phone",
      "name": "Phone number",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Phone number" },
        { "type": "text", "id": "description", "label": "Helper text" },
        { "type": "text", "id": "field_key", "label": "Field key", "info": "Used as the field name in the email you receive.", "default": "phone" },
        { "type": "text", "id": "placeholder", "label": "Placeholder", "default": "(555) 555-5555" },
        { "type": "checkbox", "id": "required", "label": "Required", "default": false }
      ]
    },
    {
      "type": "field_date",
      "name": "Date",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Preferred date" },
        { "type": "text", "id": "description", "label": "Helper text" },
        { "type": "text", "id": "field_key", "label": "Field key", "info": "Used as the field name in the email you receive.", "default": "preferred-date" },
        { "type": "text", "id": "date_min", "label": "Earliest date", "info": "Format: YYYY-MM-DD. Leave blank for no limit." },
        { "type": "text", "id": "date_max", "label": "Latest date", "info": "Format: YYYY-MM-DD. Leave blank for no limit." },
        { "type": "checkbox", "id": "required", "label": "Required", "default": false }
      ]
    },
    {
      "type": "field_dropdown",
      "name": "Dropdown",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Select an option" },
        { "type": "text", "id": "description", "label": "Helper text" },
        { "type": "text", "id": "field_key", "label": "Field key", "info": "Used as the field name in the email you receive.", "default": "custom-field" },
        { "type": "text", "id": "placeholder", "label": "Placeholder", "default": "Select an option" },
        { "type": "textarea", "id": "options", "label": "Options", "info": "Comma-separated. Example: Morning, Afternoon, Evening" },
        { "type": "checkbox", "id": "required", "label": "Required", "default": false }
      ]
    },
    {
      "type": "field_radio",
      "name": "Radio buttons",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Choose one" },
        { "type": "text", "id": "description", "label": "Helper text" },
        { "type": "text", "id": "field_key", "label": "Field key", "info": "Used as the field name in the email you receive.", "default": "custom-field" },
        { "type": "textarea", "id": "options", "label": "Options", "info": "Comma-separated. Example: Yes, No, Maybe" },
        { "type": "checkbox", "id": "required", "label": "Required", "default": false }
      ]
    },
    {
      "type": "field_checkbox",
      "name": "Checkbox",
      "settings": [
        { "type": "text", "id": "label", "label": "Field label", "info": "Shown above the checkbox group" },
        { "type": "text", "id": "description", "label": "Helper text" },
        { "type": "text", "id": "field_key", "label": "Field key", "info": "Used as the field name in the email you receive.", "default": "custom-field" },
        { "type": "richtext", "id": "checkbox_label", "label": "Checkbox text", "info": "Text shown next to the checkbox. Supports links and basic formatting." },
        { "type": "checkbox", "id": "required", "label": "Required", "default": false }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Submit button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Submit"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "button",           "label": "Primary"   },
        { "value": "button-secondary", "label": "Secondary" },
        { "value": "link",             "label": "Link"      }
      ],
      "default": "button"
    },
    {
      "type": "header",
      "content": "Field label & text typography"
    },
    {
      "type": "select",
      "id": "field_type_preset",
      "label": "Preset",
      "options": [
        { "value": "rte",       "label": "Default"   },
        { "value": "paragraph", "label": "Paragraph" },
        { "value": "h5",        "label": "H5"        },
        { "value": "h6",        "label": "H6"        },
        { "value": "custom",    "label": "Custom"    }
      ],
      "default": "rte",
      "info": "Applies to field labels, helper text, and placeholders"
    },
    {
      "type": "select",
      "id": "field_font",
      "label": "Font",
      "options": [
        { "value": "var(--font-body--family)",       "label": "Body"       },
        { "value": "var(--font-subheading--family)", "label": "Subheading" },
        { "value": "var(--font-heading--family)",    "label": "Heading"    },
        { "value": "var(--font-accent--family)",     "label": "Accent"     }
      ],
      "default": "var(--font-body--family)",
      "visible_if": "{{ section.settings.field_type_preset == 'custom' }}"
    },
    {
      "type": "select",
      "id": "field_font_size",
      "label": "Size",
      "options": [
        { "value": "",        "label": "Default" },
        { "value": "0.75rem", "label": "12px"    },
        { "value": "0.875rem","label": "14px"    },
        { "value": "1rem",    "label": "16px"    },
        { "value": "1.125rem","label": "18px"    },
        { "value": "1.25rem", "label": "20px"    }
      ],
      "default": "",
      "visible_if": "{{ section.settings.field_type_preset == 'custom' }}"
    },
    {
      "type": "select",
      "id": "field_letter_spacing",
      "label": "Letter spacing",
      "options": [
        { "value": "tight",  "label": "Tight"  },
        { "value": "normal", "label": "Normal" },
        { "value": "loose",  "label": "Loose"  }
      ],
      "default": "normal",
      "visible_if": "{{ section.settings.field_type_preset == 'custom' }}"
    },
    {
      "type": "select",
      "id": "field_case",
      "label": "Case",
      "options": [
        { "value": "none",      "label": "Default"   },
        { "value": "uppercase", "label": "Uppercase" }
      ],
      "default": "none",
      "visible_if": "{{ section.settings.field_type_preset == 'custom' }}"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "content_direction",
      "label": "Direction",
      "options": [
        { "value": "column", "label": "Vertical"   },
        { "value": "row",    "label": "Horizontal" }
      ],
      "default": "column"
    },
    {
      "type": "checkbox",
      "id": "vertical_on_mobile",
      "label": "Stack on mobile",
      "default": true
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Height",
      "options": [
        { "value": "",            "label": "Auto"        },
        { "value": "small",       "label": "Small"       },
        { "value": "medium",      "label": "Medium"      },
        { "value": "large",       "label": "Large"       },
        { "value": "full-screen", "label": "Full screen" },
        { "value": "custom",      "label": "Custom"      }
      ],
      "default": ""
    },
    {
      "type": "range",
      "id": "section_height_custom",
      "label": "Custom height",
