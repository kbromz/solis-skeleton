{% comment %}
  sections/header.liquid  (REPLACE Skeleton's header.liquid with this)
  Logo (image + inverse + width + position), menu with position + row
  (inline or bottom bar), full typography for menu and submenu, search /
  account / cart, Book-now CTA, sticky, full-width bar, mobile drawer.
  Inverse logo + .header--transparent are wired for the later transparent-
  header pass. Deferred: mega menu (collection images / featured / tiles),
  localization.
{% endcomment %}

{%- liquid
  assign s = section.settings
  assign menu = s.menu
  assign logo_image = s.logo | default: settings.logo
  assign logo_inverse = s.logo_inverse | default: settings.logo_inverse
  assign drawer_menu = s.drawer_menu | default: menu

  case s.menu_position
    when 'center'
      assign menu_align = 'center'
    when 'right'
      assign menu_align = 'end'
    else
      assign menu_align = 'start'
  endcase
-%}

<header
  class="header full-width color-{{ s.color_scheme }} header--logo-{{ s.logo_position }} header--menu-{{ s.menu_row }}{% if s.force_drawer_desktop %} header--force-drawer{% endif %}{% if s.enable_sticky_header == 'always' %} header--sticky{% endif %}"
  style="
    --header-divider: {{ s.divider_width }}px;
    --header-pad: {{ s.padding_block }}px;
    --logo-w: {{ s.logo_width }}px;
    --logo-w-mobile: {{ s.logo_width_mobile }}px;
    --menu-align: {{ menu_align }};
    --menu-font: var(--font-{{ s.menu_font }}--family);
    --menu-size: {{ s.menu_size }};
    --menu-weight: {{ s.menu_weight }};
    --menu-spacing: {{ s.menu_spacing }};
    --menu-case: {{ s.menu_case }};
    --submenu-font: var(--font-{{ s.submenu_font }}--family);
    --submenu-size: {{ s.submenu_size }};
    --submenu-weight: {{ s.submenu_weight }};
    --submenu-spacing: {{ s.submenu_spacing }};
    --submenu-case: {{ s.submenu_case }};
  "
>
  <div class="header__inner page-width">
    {%- if s.menu_row == 'top' -%}
      <nav class="header__menu" aria-label="Primary">
        {%- render 'header-menu', menu: menu, s: s -%}
      </nav>
    {%- endif -%}

    <div class="header__logo">
      {%- if logo_image != blank -%}
        <a href="{{ routes.root_url }}" class="header__logo-link" aria-label="{{ shop.name }}">
          {{ logo_image | image_url: width: 600 | image_tag: loading: 'eager', class: 'header__logo-img header__logo-img--default', widths: '150,300,450,600', alt: shop.name }}
          {%- if logo_inverse != blank -%}
            {{ logo_inverse | image_url: width: 600 | image_tag: loading: 'eager', class: 'header__logo-img header__logo-img--inverse', widths: '150,300,450,600', alt: shop.name }}
          {%- endif -%}
        </a>
      {%- else -%}
        <a href="{{ routes.root_url }}" class="header__logo-text">{{ shop.name }}</a>
      {%- endif -%}
    </div>

    <div class="header__actions">
      {%- if s.show_search -%}
        <a href="{{ routes.search_url }}" class="header__icon" aria-label="Search">
          <svg viewBox="0 0 20 20" width="20" height="20" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.5"/><path d="m14 14 4 4" stroke="currentColor" stroke-width="1.5"/></svg>
        </a>
      {%- endif -%}

      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="header__icon" aria-label="Account">
          {{ 'icon-account.svg' | inline_asset_content }}
        </a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="header__icon header__cart" aria-label="Cart">
        {{ 'icon-cart.svg' | inline_asset_content }}
        {%- if cart.item_count > 0 -%}<sup class="header__cart-count">{{ cart.item_count }}</sup>{%- endif -%}
      </a>

      {%- if s.header_cta_enabled and s.header_cta_label != blank -%}
        <a href="{{ s.header_cta_link }}" class="button button--{{ s.header_cta_style }} header__cta">{{ s.header_cta_label }}</a>
      {%- endif -%}

      <button type="button" class="header__burger" aria-label="Open menu" data-drawer-open>
        <svg viewBox="0 0 22 16" width="22" height="16" fill="none" aria-hidden="true"><path d="M0 1h22M0 8h22M0 15h22" stroke="currentColor" stroke-width="1.5"/></svg>
      </button>
    </div>
  </div>

  {%- if s.menu_row == 'bottom' -%}
    <div class="header__bottom">
      <nav class="header__menu page-width" aria-label="Primary">
        {%- render 'header-menu', menu: menu, s: s -%}
      </nav>
    </div>
  {%- endif -%}
</header>

<dialog
  class="header__drawer color-{{ s.drawer_color_scheme }}{% if s.force_drawer_desktop %} header__drawer--desktop{% endif %}"
  scroll-lock
  style="--drawer-w-desktop: {{ s.drawer_width_desktop }}%;"
>
  <div class="header__drawer-head">
    <button type="button" class="header__drawer-close" aria-label="Close menu" data-drawer-close>
      <svg viewBox="0 0 18 18" width="18" height="18" fill="none" aria-hidden="true"><path d="m1 1 16 16M17 1 1 17" stroke="currentColor" stroke-width="1.5"/></svg>
    </button>
  </div>
  <nav class="header__drawer-nav" aria-label="Mobile">
    <ul class="header__drawer-list">
      {%- for link in drawer_menu.links -%}
        <li>
          {%- if link.links != blank -%}
            <details>
              <summary>{{ link.title }}</summary>
              <ul>
                {%- for child in link.links -%}
                  <li><a href="{{ child.url }}">{{ child.title }}</a></li>
                {%- endfor -%}
              </ul>
            </details>
          {%- else -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endif -%}
        </li>
      {%- endfor -%}
        {%- if s.header_cta_enabled and s.header_cta_label != blank -%}
      <a href="{{ s.header_cta_link }}" class="button button--{{ s.header_cta_style }} header__drawer-cta">{{ s.header_cta_label }}</a>
    {%- endif -%}
    </ul>
  </nav>

  <div class="header__drawer-footer">
 

    {%- if s.drawer_show_account and shop.customer_accounts_enabled -%}
      <a href="{{ routes.account_url }}" class="header__drawer-account">
        {{ 'icon-account.svg' | inline_asset_content }}
        <span>{% if customer %}Account{% else %}Log in{% endif %}</span>
      </a>
    {%- endif -%}

    {%- if s.drawer_show_social -%}
      {%- render 'social-links' -%}
    {%- endif -%}
  </div>
</dialog>

{% stylesheet %}
  .header {
    position: relative;
    background-color: var(--color-background);
    color: var(--color-foreground);
    border-block-end: var(--header-divider, 0) solid var(--color-foreground);
  }
  .header--sticky { position: sticky; top: 0; z-index: 50; }

  .header__inner {
    display: grid;
    align-items: center;
    gap: 1rem;
    min-height: 5rem;
    padding-block: var(--header-pad, 0);
    grid-template-columns: 1fr auto 1fr;
  }

  /* Logo positions (DOM order: menu, logo, actions) */
  .header--logo-center .header__menu    { grid-column: 1; justify-self: var(--menu-align); }
  .header--logo-center .header__logo    { grid-column: 2; justify-self: center; }
  .header--logo-center .header__actions { grid-column: 3; justify-self: end; }

  .header--logo-left .header__logo    { grid-column: 1; justify-self: start; }
  .header--logo-left .header__menu    { grid-column: 2; justify-self: var(--menu-align); }
  .header--logo-left .header__actions { grid-column: 3; justify-self: end; }

  .header--logo-right .header__actions { grid-column: 1; justify-self: start; }
  .header--logo-right .header__menu    { grid-column: 2; justify-self: var(--menu-align); }
  .header--logo-right .header__logo    { grid-column: 3; justify-self: end; }

  /* Bottom bar */
  .header__bottom {
    border-block-start: var(--header-divider, 0) solid var(--color-foreground);
  }
  .header--menu-bottom .header__bottom .header__menu {
    display: flex;
    justify-content: var(--menu-align);
    padding-block: 0.75rem;
  }

  /* Logo */
  .header__logo-img { width: var(--logo-w, 120px); height: auto; max-width: 100%; }
  .header__logo-img--inverse { display: none; }
  .header--transparent .header__logo-img--default { display: none; }
  .header--transparent .header__logo-img--inverse { display: block; }
  .header__logo-text { font-family: var(--font-heading--family); font-size: 1.25rem; }

  /* Menu typography */
  .header__menu-list {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .header__item { position: relative; }
  .header__link {
    font-family: var(--menu-font);
    font-size: var(--menu-size);
    font-weight: var(--menu-weight);
    letter-spacing: var(--menu-spacing);
    text-transform: var(--menu-case);
    white-space: nowrap;
  }
  .header__submenu {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 12rem;
    display: grid;
    gap: 0.5rem;
    padding: 1rem;
    margin: 0;
    list-style: none;
    background-color: var(--color-background);
    border: 1px solid var(--color-foreground);
    border-radius: var(--popover-radius, 8px);
    opacity: 0;
    visibility: hidden;
    transform: translateY(0.25rem);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
    z-index: 40;
  }
  .header__item--has-submenu:hover .header__submenu,
  .header__item--has-submenu:focus-within .header__submenu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .header__sublink {
    font-family: var(--submenu-font);
    font-size: var(--submenu-size);
    font-weight: var(--submenu-weight);
    letter-spacing: var(--submenu-spacing);
    text-transform: var(--submenu-case);
    white-space: nowrap;
  }

  /* Mega menu */
  .header__item--has-mega { position: static; }
  .header__mega {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background-color: var(--color-background);
    color: var(--color-foreground);
    border-block-start: 1px solid var(--color-foreground);
    opacity: 0;
    visibility: hidden;
    transform: translateY(0.25rem);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
    z-index: 40;
  }
  .header__item--has-mega:hover .header__mega,
  .header__item--has-mega:focus-within .header__mega {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .header__mega-inner {
    max-width: var(--page-width);
    margin-inline: auto;
    padding: 2rem var(--page-margin);
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: start;
  }
  .header__mega-cols { display: flex; flex-wrap: wrap; gap: 3rem; }
  .header__mega-col { display: grid; gap: 0.75rem; align-content: start; }
  .header__mega-heading {
    font-family: var(--submenu-font);
    text-transform: var(--submenu-case);
    letter-spacing: var(--submenu-spacing);
  }
  .header__mega-sublist { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.5rem; }
  .header__mega-tiles { display: flex; gap: 1rem; }
  .header__mega-tile { display: grid; gap: 0.5rem; width: 180px; color: var(--color-foreground); }
  .header__mega-tile-img { width: 100%; aspect-ratio: var(--tile-ar, 3 / 4); object-fit: cover; border-radius: var(--popover-radius, 8px); }
  .header__mega-tile-title { font-family: var(--submenu-font); font-size: 0.9375rem; }
  .header__mega-tile-btn { justify-self: start; }

  /* Actions */
  .header__actions { display: flex; align-items: center; gap: 1rem; }
  .header__icon { display: inline-flex; align-items: center; position: relative; color: var(--color-foreground); }
  .header__icon svg { width: 1.375rem; height: auto; }
  .header__cart-count { position: absolute; top: -0.4rem; left: 100%; font-size: 0.6875rem; }
  .header__cta { margin-inline-start: 0.5rem; }

  .header__burger { display: none; background: none; border: 0; padding: 0; color: var(--color-foreground); cursor: pointer; }

  /* Mobile drawer */
  .header__drawer {
    margin: 0;
    height: 100dvh; max-height: 100dvh;
    width: 100vw; max-width: 100vw;
    border: 0; padding: 1.25rem;
    background-color: var(--color-background); color: var(--color-foreground);
    flex-direction: column;
  }
  .header__drawer[open] { display: flex; }
  .header__drawer::backdrop { background: rgba(0,0,0,0.4); }
  .header__drawer-head { display: flex; justify-content: flex-end; }
  .header__drawer-close { background: none; border: 0; padding: 0.25rem; color: var(--color-foreground); cursor: pointer; }
  .header__drawer-nav { flex: 1 1 auto; }
  .header__drawer-list { list-style: none; margin: 0; padding: 0; display: grid; gap: 1rem; }
  .header__drawer-list a, .header__drawer-list summary {
    font-family: var(--menu-font); font-size: 1.0625rem; text-transform: var(--menu-case); cursor: pointer;
  }
  .header__drawer-list details ul { list-style: none; padding-inline-start: 1rem; margin-block-start: 0.75rem; display: grid; gap: 0.75rem; }
  .header__drawer-footer {
    margin-block-start: auto;
    display: grid; gap: 1rem;
    padding-block-start: 1.5rem;
    border-block-start: 1px solid var(--color-foreground);
  }
  .header__drawer-cta { width: 100%; }
  .header__drawer-account { display: inline-flex; align-items: center; gap: 0.5rem; }
  .header__drawer-account svg { width: 1.25rem; height: auto; }

  /* Force drawer on desktop */
  .header--force-drawer .header__menu { display: none; }
  .header--force-drawer .header__bottom { display: none; }
  .header--force-drawer .header__burger { display: inline-flex; }

  @media screen and (max-width: 749px) {
    .header__menu { display: none; }
    .header--menu-bottom .header__bottom { display: none; }
    .header__cta { display: none; }
    .header__burger { display: inline-flex; }
    .header__logo-img { width: var(--logo-w-mobile, 90px); }
    .header__inner { grid-template-columns: auto 1fr auto; }
    .header--logo-center .header__logo { justify-self: center; }
  }
  @media screen and (min-width: 750px) {
    /* The standard drawer is mobile-only; the desktop drawer opts in */
    .header__drawer:not(.header__drawer--desktop)[open] { display: none; }
    .header__drawer--desktop {
      width: var(--drawer-w-desktop, 35%);
      max-width: var(--drawer-w-desktop, 35%);
      margin-inline-start: auto;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    var drawer = document.querySelector('.header__drawer');
    if (!drawer || drawer.dataset.bound) return;
    drawer.dataset.bound = '1';
    document.querySelectorAll('[data-drawer-open]').forEach(function (b) {
      b.addEventListener('click', function () { drawer.showModal(); });
    });
    document.querySelectorAll('[data-drawer-close]').forEach(function (b) {
      b.addEventListener('click', function () { drawer.close(); });
    });
    drawer.addEventListener('click', function (e) { if (e.target === drawer) drawer.close(); });
  })();
</script>

